# Discord Bot Token — get from https://discord.com/developers/applications
DISCORD_TOKEN=your-bot-token-here

# Application (Client) ID — found on the "General Information" page
CLIENT_ID=your-client-id-here

# Guild ID for development command registration (instant updates)
# Leave blank or remove for global command registration (takes ~1hr to propagate)
GUILD_ID=your-dev-guild-id-here
